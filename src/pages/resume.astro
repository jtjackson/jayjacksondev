---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume - Jay Jackson" description="Professional experience and skills. Senior Software Engineer with 20+ years in tech, specializing in web development, C/C++, Python, and cloud native technologies.">
  <div class="max-w-4xl mx-auto px-4 py-16 space-y-16">
    <!-- Hero -->
    <section class="space-y-4">
      <h1 class="text-5xl font-bold text-blue-600 dark:text-green-400 dark:drop-shadow-[0_0_20px_rgba(0,255,65,0.3)]">
        Resume
      </h1>
      <p class="text-xl text-gray-700 dark:text-gray-300">
        Professional Experience & Skills
      </p>
    </section>

    <!-- Experience -->
    <section class="space-y-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Experience</h2>

      <div class="space-y-8">
        <div class="space-y-2 pb-8 border-b border-gray-200 dark:border-green-500/20 last:border-b-0">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">Senior Software Engineer</h3>
          <p class="text-gray-600 dark:text-gray-400">CallRevu · Remote • May 2024 - Present</p>
        </div>

        <div class="space-y-2 pb-8 border-b border-gray-200 dark:border-green-500/20">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">Senior Software Engineer</h3>
          <p class="text-gray-600 dark:text-gray-400">TotalCX (formerly InteractiveTel) · Cypress, TX • May 2019 - May 2024 · 5 yrs 1 mo</p>
        </div>

        <div class="space-y-3 pb-8 border-b border-gray-200 dark:border-green-500/20">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">Software Engineer</h3>
          <p class="text-gray-600 dark:text-gray-400">Kinesix Software · Houston, TX • Jan 2014 - Apr 2019 · 5 yrs 4 mos</p>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300 pl-5">
            <li>• Designed and prototyped system architecture using Node.js, Redis, WebGL/HTML5</li>
            <li>• Developed C++ modules with Qt and Python integration</li>
            <li>• Improved GPU rendering performance using various graphics libraries</li>
            <li>• Migrated .NET applications from WinForms to WPF</li>
            <li>• Provided technical support for aerospace and defense clients</li>
          </ul>
        </div>

        <div class="space-y-3 pb-8 border-b border-gray-200 dark:border-green-500/20">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">QA Engineer</h3>
          <p class="text-gray-600 dark:text-gray-400">Kinesix Software · Houston, TX • Aug 2005 - Jan 2014 · 8 yrs 6 mos</p>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300 pl-5">
            <li>• Led QA team for Beijing Olympics Metro Line System project</li>
            <li>• Implemented test automation using shell scripts and TestComplete</li>
            <li>• Managed CI/CD processes and virtual machine infrastructure</li>
            <li>• Supervised QA department of 2-3 testers</li>
          </ul>
        </div>

        <div class="space-y-3">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">Assistive Technology Lab Assistant</h3>
          <p class="text-gray-600 dark:text-gray-400">North Harris College · Houston, TX • Oct 2002 - Aug 2005 · 2 yrs 11 mos</p>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300 pl-5">
            <li>• Managed computer lab for students with disabilities</li>
            <li>• Implemented OCR technology and database systems</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="space-y-8 pt-8 border-t border-gray-200 dark:border-green-500/20">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Skills</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="space-y-3">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Languages</h3>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300">
            <li>C/C++</li>
            <li>Python</li>
            <li>JavaScript/Node.js</li>
            <li>C#/.NET</li>
            <li>Ruby on Rails</li>
            <li>Shell Scripting</li>
          </ul>
        </div>

        <div class="space-y-3">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Technologies</h3>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300">
            <li>Vue.js/Nuxt</li>
            <li>Qt/GTK+</li>
            <li>WebGL/HTML5</li>
            <li>Redis</li>
            <li>WebSockets</li>
            <li>WPF/WinForms</li>
          </ul>
        </div>

        <div class="space-y-3">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Tools & Platforms</h3>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300">
            <li>Linux/Unix</li>
            <li>Windows</li>
            <li>Git/SVN</li>
            <li>CI/CD</li>
            <li>Kubernetes</li>
            <li>Virtualization</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="space-y-6 pt-8 border-t border-gray-200 dark:border-green-500/20">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Education</h2>

      <div class="space-y-2">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">Bachelor of Science - Physics</h3>
        <p class="text-gray-600 dark:text-gray-400">Texas A&M University • 1996 - 2000</p>
      </div>
    </section>

    <!-- Download -->
    <section class="pt-8 border-t border-gray-200 dark:border-green-500/20">
      <a
        href="#"
        class="inline-flex items-center text-blue-600 dark:text-green-400 hover:text-blue-700 dark:hover:text-green-300 font-semibold transition-colors"
      >
        Download PDF Resume →
      </a>
    </section>
  </div>
</Layout>
