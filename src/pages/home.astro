---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Home - Jay Jackson"
  description="Software engineer, physics nerd, tinkerer, lifelong learner. Exploring cloud native technologies, learning eBPF, and building interesting projects."
>
  <div class="max-w-4xl mx-auto px-4 py-16 space-y-16">
    <!-- Hero / Intro -->
    <section class="space-y-6">
      <h1 class="text-5xl md:text-6xl font-bold text-blue-600 dark:text-green-400 dark:drop-shadow-[0_0_20px_rgba(0,255,65,0.3)]">
        👋 Howdy
      </h1>
      <p class="text-2xl text-gray-700 dark:text-gray-300">
        Software engineer, physics nerd, tinkerer, lifelong learner.
      </p>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl">
        I am Jay. I've been breaking and fixing things in tech for over 20 years. I'm also Deaf, a writer,
        husband to the most amazing woman I know, and dad to the best kids in the universe.
        These days I'm exploring cloud native technologies, learning eBPF, and tinkering with whatever
        catches my curiosity.
      </p>
      <p>
        <a href="/about" class="text-blue-600 dark:text-green-400 hover:text-blue-700 dark:hover:text-green-300 font-semibold transition-colors">
          Want to learn more about my journey? →
        </a>
      </p>
    </section>

    <!-- What I'm Up To -->
    <section class="space-y-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">What I'm up to</h2>
      <div class="space-y-4 text-lg text-gray-700 dark:text-gray-300">
        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-blue-600 dark:text-green-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.6 16.6l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4m-5.2 0L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4z"/>
          </svg>
          <div>
            <span class="font-semibold text-gray-900 dark:text-white">Building with:</span> Vue.js, Nuxt, Python, C/C++, Ruby on Rails
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-blue-600 dark:text-green-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3m6.82 6L12 12.72 5.18 9 12 5.28 18.82 9M17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/>
          </svg>
          <div>
            <span class="font-semibold text-gray-900 dark:text-white">Learning:</span> eBPF, Kubernetes, cloud native observability
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <svg class="w-6 h-6 text-blue-600 dark:text-green-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313-12.454z"/>
          </svg>
          <div>
            <span class="font-semibold text-gray-900 dark:text-white">Tinkering:</span> Personal projects, frameworks I've never used before, Linux automation
          </div>
        </div>
      </div>
    </section>

    <!-- Interests -->
    <section class="space-y-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Things I enjoy</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-300">
          <svg class="w-5 h-5 text-blue-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/>
          </svg>
          <span>Reading & writing</span>
        </div>
        <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-300">
          <svg class="w-5 h-5 text-blue-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.6 16.6l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4m-5.2 0L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4z"/>
          </svg>
          <span>Side projects</span>
        </div>
        <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-300">
          <svg class="w-5 h-5 text-blue-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 6h-7.59l3.29-3.29L16 2l-4 4-4-4-.71.71L10.59 6H3a2 2 0 0 0-2 2v12c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8a2 2 0 0 0-2-2m0 14H3V8h18v12z"/>
          </svg>
          <span>Watching sports</span>
        </div>
        <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-300">
          <svg class="w-5 h-5 text-blue-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
          </svg>
          <span>Science & physics</span>
        </div>
        <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-300">
          <svg class="w-5 h-5 text-blue-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21.58 16.09l-1.09-7.66A1.003 1.003 0 0 0 19.5 7.5h-1l-.85-2.55c-.2-.61-.77-1.03-1.42-1.03H7.77c-.65 0-1.22.42-1.42 1.03L5.5 7.5h-1c-.49 0-.9.36-.98.85l-1.09 7.66a.991.991 0 0 0 .97 1.15h.02c.46 0 .85-.32.97-.78l1.34-4.94h3.77l-.07.19A2.97 2.97 0 0 0 12 14.79a2.97 2.97 0 0 0 2.57-3.16l-.07-.19h3.77l1.34 4.94c.12.46.51.78.97.78h.02a.991.991 0 0 0 .98-1.07zM9 12c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm3-5.92L12.5 4h-.99l.49 2.08zm3 5.92c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
          </svg>
          <span>Video games</span>
        </div>
        <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-300">
          <svg class="w-5 h-5 text-blue-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11 2v2l-7 3v2l7-3v9a4 4 0 1 0 2 0V6l7 3V7l-7-3V2h-2m1 16a2 2 0 0 1-2 2 2 2 0 0 1-2-2 2 2 0 0 1 2-2 2 2 0 0 1 2 2z"/>
          </svg>
          <span>Family time</span>
        </div>
      </div>
    </section>

    <!-- Connect -->
    <section class="space-y-6">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Connect</h2>
      <p class="text-lg text-gray-700 dark:text-gray-300">
        Feel free to reach out if you want to chat about tech, collaborate on a project, or just say hello.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://github.com/jtjackson"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit my GitHub profile (opens in new tab)"
          class="inline-flex items-center space-x-2 px-6 py-3 bg-white dark:bg-gray-900 border-2 border-gray-300 dark:border-green-500/30 rounded-lg text-gray-700 dark:text-gray-300 hover:border-blue-600 dark:hover:border-green-500 hover:text-blue-600 dark:hover:text-green-400 transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="font-semibold">GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/james-t-jackson/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit my LinkedIn profile (opens in new tab)"
          class="inline-flex items-center space-x-2 px-6 py-3 bg-white dark:bg-gray-900 border-2 border-gray-300 dark:border-green-500/30 rounded-lg text-gray-700 dark:text-gray-300 hover:border-blue-600 dark:hover:border-green-500 hover:text-blue-600 dark:hover:text-green-400 transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="font-semibold">LinkedIn</span>
        </a>
        <a
          href="https://bsky.app/profile/jjackson.bsky.social"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit my Bluesky profile (opens in new tab)"
          class="inline-flex items-center space-x-2 px-6 py-3 bg-white dark:bg-gray-900 border-2 border-gray-300 dark:border-green-500/30 rounded-lg text-gray-700 dark:text-gray-300 hover:border-blue-600 dark:hover:border-green-500 hover:text-blue-600 dark:hover:text-green-400 transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.271-.04.407-.056-3.912.448-7.523 1.207-7.523 3.936 0 .957.606 1.687 1.65 2.183 1.462.696 3.59.962 5.457.962 4.632 0 8.002-1.584 8.002-5.07 0-2.729-3.61-3.488-7.522-3.936.136.017.27.036.406.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/>
          </svg>
          <span class="font-semibold">Bluesky</span>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center space-x-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-green-500 dark:hover:bg-green-600 text-white dark:text-black rounded-lg font-semibold transition-all shadow-lg"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          <span>Send a message</span>
        </a>
      </div>
    </section>

    <!-- Quick Links to Other Pages -->
    <section class="pt-8 border-t border-gray-200 dark:border-green-500/20">
      <div class="flex flex-wrap gap-6 text-lg">
        <a href="/blog" class="text-blue-600 dark:text-green-400 hover:text-blue-700 dark:hover:text-green-300 font-semibold transition-colors">
          Read my blog →
        </a>
        <a href="/projects" class="text-blue-600 dark:text-green-400 hover:text-blue-700 dark:hover:text-green-300 font-semibold transition-colors">
          See my projects →
        </a>
        <a href="/resume" class="text-blue-600 dark:text-green-400 hover:text-blue-700 dark:hover:text-green-300 font-semibold transition-colors">
          View my resume →
        </a>
      </div>
    </section>
  </div>
</Layout>
